{
  "expo": {
    "name": "Do Eventer",
    "slug": "do-eventer",
    "version": "0.8.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "do-eventer",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F5F3EC",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.doeventer"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.example.doeventer"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5F3EC",
          "dark": {
            "backgroundColor": "#F5F3EC"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "招待QRコードを読み取るためにカメラを使用します。",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "イベント予定を端末カレンダーへ追加するために使用します。"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "イベント場所を現在地から探すために位置情報を使用します。"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#285943",
          "defaultChannel": "event-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
